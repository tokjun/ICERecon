     <layout class="QFormLayout" name="inputsFormLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="inputSegmentationLabel">
        <property name="text">
         <string>Segmentation:</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="qMRMLNodeComboBox" name="inputSegmentation">
        <property name="nodeTypes">
         <stringlist>
          <string>vtkMRMLSegmentationNode</string>
         </stringlist>
        </property>
        <property name="noneEnabled">
         <bool>true</bool>
        </property>
        <property name="addEnabled">
         <bool>false</bool>
        </property>
        <property name="removeEnabled">
         <bool>false</bool>
        </property>
        <property name="toolTip">
         <string>3D segmentation of the heart chambers and vessels.</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="imagingPlaneTransformLabel">
        <property name="text">
         <string>Imaging plane transform:</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="qMRMLNodeComboBox" name="imagingPlaneTransform">
        <property name="nodeTypes">
         <stringlist>
          <string>vtkMRMLLinearTransformNode</string>
         </stringlist>
        </property>
        <property name="noneEnabled">
         <bool>true</bool>
        </property>
        <property name="addEnabled">
         <bool>true</bool>
        </property>
        <property name="removeEnabled">
         <bool>false</bool>
        </property>
        <property name="toolTip">
         <string>Linear transform representing the position and orientation of the imaging plane, attached to the ICE probe.</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="ctkCollapsibleButton" name="parametersCollapsibleButton">
     <property name="text">
      <string>Parameters</string>
     </property>
     <layout class="QFormLayout" name="parametersFormLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="scanPlaneOrientationLabel">
        <property name="text">
         <string>Scan plane orientation:</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QComboBox" name="scanPlaneOrientation">
        <property name="toolTip">
         <string>Perpendicular: imaging plane is perpendicular to the catheter (the transform's third column vector is the plane normal). Parallel (forward): imaging plane contains the catheter axis, extending forward from the tip. Parallel (side): the Parallel (forward) plane rotated 90 degrees about the transform's second column vector (perpendicular to the catheter), pivoting on the tip, so the near edge of the image runs along the catheter.</string>
        </property>
        <item>
         <property name="text">
          <string>Perpendicular</string>
         </property>
        </item>
        <item>
         <property name="text">
          <string>Parallel (forward)</string>
         </property>
        </item>
        <item>
         <property name="text">
          <string>Parallel (side)</string>
         </property>
        </item>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="viewAngleDegLabel">
        <property name="text">
         <string>View angle (deg):</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QDoubleSpinBox" name="viewAngleDeg">
        <property name="toolTip">
         <string>Full opening angle of the fan-shaped imaging area. The apex is at the center of the image's near edge (the catheter); pixels outside the fan are set to zero.</string>
        </property>
        <property name="decimals">
         <number>1</number>
        </property>
        <property name="minimum">
         <double>1.000000000000000</double>
        </property>
        <property name="maximum">
         <double>179.000000000000000</double>
        </property>
        <property name="value">
         <double>90.000000000000000</double>
        </property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QLabel" name="rangeLabel">
        <property name="text">
         <string>Range (min, max) [mm]:</string>
        </property>
       </widget>
      </item>
      <item row="2" column="1">
       <layout class="QHBoxLayout" name="rangeLayout">
        <item>
         <widget class="QDoubleSpinBox" name="minRangeMm">
          <property name="toolTip">
           <string>Minimum radial distance from the fan's apex (the catheter) that is rendered; pixels closer than this are set to zero.</string>
          </property>
          <property name="decimals">
           <number>1</number>
          </property>
          <property name="minimum">
           <double>0.000000000000000</double>
          </property>
          <property name="maximum">
           <double>1000.000000000000000</double>
          </property>
          <property name="value">
           <double>0.000000000000000</double>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QDoubleSpinBox" name="maxRangeMm">
          <property name="toolTip">
           <string>Maximum radial distance from the fan's apex (the catheter) that is rendered; pixels farther than this are set to zero.</string>
          </property>
          <property name="decimals">
           <number>1</number>
          </property>
          <property name="minimum">
           <double>0.000000000000000</double>
          </property>
          <property name="maximum">
           <double>1000.000000000000000</double>
          </property>
          <property name="value">
           <double>200.000000000000000</double>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item row="3" column="0">
       <widget class="QLabel" name="matrixSizeLabel">
        <property name="text">
